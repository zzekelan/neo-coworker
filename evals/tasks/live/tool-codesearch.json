{
  "id": "live/tool-codesearch",
  "providerMode": "live",
  "prompt": "Use codesearch to investigate the query SEARCH_BACKEND_TOKEN_CODE. Summarize the most relevant API-oriented result you found.",
  "workspaceFixture": "workspaces/basic",
  "permissionPolicy": {
    "codesearch": "allow"
  },
  "traceExpectation": {
    "requiredEventTypes": [
      "run.started",
      "tool.call.completed",
      "run.completed"
    ]
  },
  "outcomeExpectation": {
    "runStatus": "completed"
  },
  "protocolExpectation": {
    "requiredRuntimeEventTypes": [
      "run.started",
      "tool.call.completed",
      "run.completed"
    ],
    "forbiddenRuntimeEventTypes": [
      "run.failed",
      "run.cancelled"
    ]
  },
  "toolPolicyExpectation": {
    "requiredToolNames": [
      "codesearch"
    ],
    "forbiddenToolNames": [
      "write",
      "edit",
      "shell"
    ]
  },
  "transcriptExpectation": {
    "checkpoints": [
      {
        "messageIndex": 1,
        "role": "assistant",
        "partKinds": [
          "tool_call",
          "tool_result"
        ],
        "toolNames": [
          "codesearch"
        ]
      }
    ]
  },
  "traceSequenceExpectation": {
    "orderedEventTypes": [
      "run.started",
      "tool.call.completed",
      "run.completed"
    ]
  }
}
