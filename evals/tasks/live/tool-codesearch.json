{
  "id": "live/tool-codesearch",
  "providerMode": "live",
  "prompt": "Use only the codesearch tool to investigate URLSearchParams. Do not use webfetch, websearch, grep, shell, read, write, or edit. Reply with the exact MDN URL you found and the exact baseline-availability month and year mentioned in the result.",
  "workspaceFixture": "workspaces/basic",
  "permissionPolicy": {
    "codesearch": "allow"
  },
  "autoReplyPermission": "deny",
  "traceExpectation": {
    "requiredEventTypes": [
      "run.started",
      "tool.call.completed",
      "run.completed"
    ]
  },
  "outcomeExpectation": {
    "runStatus": "completed"
  },
  "protocolExpectation": {
    "requiredRuntimeEventTypes": [
      "run.started",
      "tool.call.completed",
      "run.completed"
    ],
    "forbiddenRuntimeEventTypes": [
      "run.failed",
      "run.cancelled"
    ]
  },
  "toolPolicyExpectation": {
    "requiredToolNames": [
      "codesearch"
    ],
    "forbiddenToolNames": [
      "write",
      "edit",
      "shell"
    ]
  },
  "timelineExpectation": {
    "checkpoints": [
      {
        "messageIndex": 1,
        "role": "assistant",
        "partKinds": [
          "tool_call",
          "tool_result"
        ],
        "toolNames": [
          "codesearch"
        ]
      },
      {
        "messageIndex": 2,
        "role": "assistant",
        "textIncludes": [
          "April 2018",
          "https://developer.mozilla.org/en-US/docs/Web/API/URLSearchParams"
        ]
      }
    ]
  },
  "traceSequenceExpectation": {
    "orderedEventTypes": [
      "run.started",
      "tool.call.completed",
      "run.completed"
    ]
  },
  "toolConsumptionExpectation": {
    "requiredConsumptions": [
      {
        "toolName": "codesearch",
        "toolResultIncludes": [
          "April 2018",
          "https://developer.mozilla.org/en-US/docs/Web/API/URLSearchParams"
        ],
        "assistantTextIncludes": [
          "April 2018",
          "https://developer.mozilla.org/en-US/docs/Web/API/URLSearchParams"
        ]
      }
    ]
  }
}
