{
  "id": "live/tool-websearch",
  "providerMode": "live",
  "prompt": "Use websearch to find Alan Turing's exact birth date from the Wikipedia result. Reply with the exact date and the exact URL you used.",
  "workspaceFixture": "workspaces/basic",
  "permissionPolicy": {
    "websearch": "allow"
  },
  "autoReplyPermission": "deny",
  "traceExpectation": {
    "requiredEventTypes": [
      "run.started",
      "tool.call.completed",
      "run.completed"
    ]
  },
  "outcomeExpectation": {
    "runStatus": "completed"
  },
  "protocolExpectation": {
    "requiredRuntimeEventTypes": [
      "run.started",
      "tool.call.completed",
      "run.completed"
    ],
    "forbiddenRuntimeEventTypes": [
      "run.failed",
      "run.cancelled"
    ]
  },
  "toolPolicyExpectation": {
    "requiredToolNames": [
      "websearch"
    ],
    "forbiddenToolNames": [
      "write",
      "edit",
      "shell"
    ]
  },
  "timelineExpectation": {
    "checkpoints": [
      {
        "messageIndex": 1,
        "role": "assistant",
        "partKinds": [
          "tool_call",
          "tool_result"
        ],
        "toolNames": [
          "websearch"
        ]
      },
      {
        "messageIndex": 2,
        "role": "assistant",
        "textIncludes": [
          "23 June 1912",
          "https://en.wikipedia.org/wiki/Alan_Turing"
        ]
      }
    ]
  },
  "traceSequenceExpectation": {
    "orderedEventTypes": [
      "run.started",
      "tool.call.completed",
      "run.completed"
    ]
  },
  "toolConsumptionExpectation": {
    "requiredConsumptions": [
      {
        "toolName": "websearch",
        "toolResultIncludes": [
          "23 June 1912",
          "https://en.wikipedia.org/wiki/Alan_Turing"
        ],
        "assistantTextIncludes": [
          "23 June 1912",
          "https://en.wikipedia.org/wiki/Alan_Turing"
        ]
      }
    ]
  }
}
