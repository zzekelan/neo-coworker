{
  "id": "live/datetime",
  "providerMode": "live",
  "prompt": "Use the get_current_datetime tool exactly once. Then reply with a single sentence containing `DATETIME_LIVE_DONE` and the UTC offset reported by the tool.",
  "workspaceFixture": "workspaces/basic",
  "autoReplyPermission": "deny",
  "traceExpectation": {
    "requiredEventTypes": [
      "run.started",
      "tool.call.completed",
      "run.completed"
    ]
  },
  "outcomeExpectation": {
    "runStatus": "completed"
  },
  "protocolExpectation": {
    "requiredRuntimeEventTypes": [
      "run.started",
      "tool.call.completed",
      "run.completed"
    ],
    "forbiddenRuntimeEventTypes": [
      "permission.requested",
      "run.failed",
      "run.cancelled"
    ]
  },
  "toolPolicyExpectation": {
    "requiredToolNames": [
      "get_current_datetime"
    ],
    "forbiddenToolNames": [
      "write",
      "edit",
      "shell"
    ]
  },
  "timelineExpectation": {
    "checkpoints": [
      {
        "messageIndex": 1,
        "role": "assistant",
        "partKinds": [
          "tool_call",
          "tool_result"
        ],
        "toolNames": [
          "get_current_datetime"
        ]
      },
      {
        "messageIndex": 2,
        "role": "assistant",
        "textIncludes": [
          "DATETIME_LIVE_DONE"
        ]
      }
    ]
  },
  "toolConsumptionExpectation": {
    "requiredConsumptions": [
      {
        "toolName": "get_current_datetime",
        "toolResultIncludes": [
          "UTC offset:"
        ],
        "assistantTextIncludes": [
          "DATETIME_LIVE_DONE"
        ]
      }
    ]
  }
}
