{
  "id": "live/skill-run-snapshot",
  "providerMode": "live",
  "prompt": "A reviewer session default skill is already configured for this run. Use only the information in this prompt and do not inspect the workspace or run tools. Briefly review this proposed change without changing the active skill set: remove the null check around providerResponse.id because it is 'always set', add exponential retry backoff for 429s, and leave the duplicate-event tests unchanged.",
  "workspaceFixture": "workspaces/skills",
  "autoReplyPermission": "deny",
  "sessionSeed": {
    "activeSkills": [
      "reviewer"
    ]
  },
  "traceExpectation": {
    "requiredEventTypes": [
      "skill.run.snapshot.applied",
      "skill.catalog.exposed",
      "model.prompt.assembled",
      "run.completed"
    ]
  },
  "outcomeExpectation": {
    "runStatus": "completed"
  },
  "protocolExpectation": {
    "requiredRuntimeEventTypes": [
      "run.started",
      "run.completed"
    ],
    "forbiddenRuntimeEventTypes": [
      "run.failed",
      "run.cancelled"
    ]
  },
  "toolPolicyExpectation": {
    "forbiddenToolNames": [
      "skill",
      "glob",
      "grep",
      "read",
      "webfetch",
      "websearch",
      "codesearch",
      "write",
      "edit",
      "shell"
    ]
  },
  "timelineExpectation": {
    "checkpoints": [
      {
        "messageIndex": 1,
        "role": "assistant",
        "textIncludes": [
          "Review:"
        ]
      }
    ]
  },
  "traceSequenceExpectation": {
    "orderedEventTypes": [
      "skill.run.snapshot.applied",
      "skill.catalog.exposed",
      "skill.load.requested",
      "skill.load.completed",
      "model.prompt.assembled",
      "run.completed"
    ]
  },
  "promptAssemblyExpectation": {
    "checkpoints": [
      {
        "promptIndex": 0,
        "catalogSkillNamesIncludes": [
          "reviewer",
          "writer"
        ],
        "activeSkillNamesIncludes": [
          "reviewer"
        ],
        "activeSkillNamesExcludes": [
          "writer"
        ],
        "activeSkillCount": 1
      }
    ],
    "requireStableSystemPromptHash": true
  }
}
